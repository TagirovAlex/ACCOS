{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./.opencode/plugins/ponytail.mjs"],
  "instructions": [".opencode/instructions.md"],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "node",
        "C:\\Github\\mcpservers\\node_modules\\@modelcontextprotocol\\server-filesystem\\dist\\index.js",
        "C:\\Github\\ACCOS"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node",
        "C:\\Github\\mcpservers\\node_modules\\@modelcontextprotocol\\server-sequential-thinking\\dist\\index.js"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "node",
        "C:\\Github\\mcpservers\\node_modules\\@modelcontextprotocol\\server-memory\\dist\\index.js"
      ],
      "enabled": true,
      "env": {
        "MEMORY_FILE_PATH": "C:\\Github\\ACCOS\\.opencode\\memory.jsonl"
      }
    },
    "git": {
      "type": "local",
      "command": [
        "C:\\Github\\mcpservers\\.venv\\Scripts\\python.exe",
        "-m",
        "mcp_server_git",
        "--repository",
        "C:\\Github\\ACCOS"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "wordex": {
      "type": "local",
      "command": [
        "node",
        "C:\\Github\\mcpservers\\node_modules\\wordex-mcp\\dist\\index.js"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "C:\\Github\\mcpservers\\.venv\\Scripts\\python.exe",
        "-m",
        "mcp_server_fetch"
      ],
      "enabled": true
    }
  },
  "permission": {
    "edit": "deny",
    "glob": "deny",
    "grep": "deny"
  },
  "experimental": {
    "mcp_timeout": 60000
  }
}
