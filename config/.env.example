# ACCOS Configuration
#
# Развёртывание в локальной сети (без домена):
#   - JWT_SECRET_KEY: сгенерируйте случайную строку (openssl rand -base64 32)
#   - CORS_ORIGINS: укажите IP сервера (http://10.0.0.100:80)
#   - Без HTTPS токены передаются в открытом виде — в доверенной
#     локальной сети это обычно приемлемо. Для усиления безопасности:
#     сократите JWT_ACCESS_TOKEN_EXPIRE_MINUTES до 15-30
#     и включите самоподписанный HTTPS (см. install_debian.sh)

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/accos

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LDAP ---
# LDAP_ENABLED=true  # раскомментировать если используется Active Directory
LDAP_SERVER=ldap://your-ldap-server:389
LDAP_DOMAIN=DOMAIN
LDAP_BASE_DN=DC=domain,DC=local

# --- LMStudio ---
LMSTUDIO_BASE_URL=http://10.82.4.99:1234/v1
LMSTUDIO_MODEL=default
LMSTUDIO_API_KEY=

# --- ComfyUI ---
COMFYUI_BASE_URL=http://10.82.4.99:8188
# COMFYUI_GENERATE_BASE_URL=   # опционально: для z_image, иначе COMFYUI_BASE_URL
# COMFYUI_EDIT_BASE_URL=       # опционально: для Qwen edit, иначе COMFYUI_BASE_URL
# COMFYUI_VIDEO_BASE_URL=      # опционально: для video, иначе COMFYUI_BASE_URL
COMFYUI_API_KEY=

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- CORS ---
# Укажите origins для доступа к API (IP сервера + порт nginx)
CORS_ORIGINS=["http://10.0.0.100:80", "http://localhost:3000"]

# --- Rate Limiting ---
# Отключите (false) на время отладки.
# Включите (true) на production — slowapi защищает от брутфорса и спама.
RATE_LIMITS_ENABLED=true

# --- Logging ---
LOG_LEVEL=DEBUG
